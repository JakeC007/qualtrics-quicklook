# Python
__pycache__/
*.pyc
.ipynb_checkpoints/
.venv/
venv/

# Generated outputs. The sample config.json is kept on purpose so the repo
# runs out of the box; everything else here is regenerated by the notebooks.
output/*
!output/config.json

# Don't commit real participant data. Keep only the synthetic sample.
sample_data/*
!sample_data/sample_qualtrics_export.csv
